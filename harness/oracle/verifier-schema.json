{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerifierVerdict",
  "description": "Required output shape from the Verifier subagent. Mandates non-empty evidence to prevent sycophantic pass verdicts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "evidence", "next_action"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail_compile", "fail_test", "fail_semantic", "needs_human"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "excerpt"],
        "properties": {
          "kind": { "type": "string", "enum": ["cargo_output", "test_log", "diff_line", "todo_marker", "trailer_field"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 0 },
          "excerpt": { "type": "string", "minLength": 1 }
        }
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "description": "One sentence: what should happen next. Not a fix proposal."
    },
    "summary": {
      "type": "string",
      "description": "Optional one-line headline."
    }
  }
}
