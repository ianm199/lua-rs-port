{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JBiYC2DLnsaiCPzUv6RMrz","type":"tool_result","content":"1\t//! Coroutine library — port of `lcorolib.c`.\n2\t//!\n3\t//! Provides the `coroutine.*` standard-library table: `create`, `resume`,\n4\t//! `running`, `status`, `wrap`, `yield`, `isyieldable`, and `close`.\n5\t//!\n6\t//! # Phase A–D stub notice\n7\t//!\n8\t//! Every function that requires actual coroutine execution (`resume`, `yield`,\n9\t//! cross-thread `xmove`, `new_thread`, `close_thread`) is **unimplemented** and\n10\t//! will panic at runtime.  The argument-checking and result-packaging logic is\n11\t//! translated faithfully so that Phase E can drop in the real implementations\n12\t//! without restructuring.  Phase E wires real stackful coroutines via\n13\t//! `corosensei`.  See PORTING.md §2 #6.\n14\t//!\n15\t//! Translated from: `reference/lua-5.4.7/src/lcorolib.c` (210 lines, 12 functions)\n16\t//! Target crate: `lua-stdlib`\n17\t\n18\t// TODO(port): LuaState, GcRef<LuaState>, LuaStatus, and related types live in\n19\t// lua-vm / lua-types; all unresolved imports will be fixed in Phase B.\n20\tuse lua_types::{\n21\t    error::LuaError,\n22\t    value::LuaValue,\n23\t    LuaType,\n24\t    LuaStatus,\n25\t    LuaClosure,\n26\t    UpValState,\n27\t    gc::GcRef,\n28\t};\n29\tuse crate::state_stub::{LuaState, LuaStateStubExt as _, lua_CFunction, upvalue_index};\n30\t\n31\t// ── Coroutine status codes ────────────────────────────────────────────────────\n32\t\n33\t// C: #define COS_RUN   0\n34\t// C: #define COS_DEAD  1\n35\t// C: #define COS_YIELD 2\n36\t// C: #define COS_NORM  3\n37\t\n38\t/// Coroutine is the currently running thread.\n39\tconst COS_RUN: i32 = 0;\n40\t\n41\t/// Coroutine has finished execution or encountered an error.\n42\tconst COS_DEAD: i32 = 1;\n43\t\n44\t/// Coroutine is suspended — either yielded or not yet started.\n45\tconst COS_YIELD: i32 = 2;\n46\t\n47\t/// Coroutine is normal — it resumed another coroutine and is waiting.\n48\tconst COS_NORM: i32 = 3;\n49\t\n50\t/// Human-readable status strings indexed by the `COS_*` constants above.\n51\t/// Pushed onto the Lua stack as byte strings.\n52\t///\n53\t/// C: `static const char *const statname[] = {\"running\",\"dead\",\"suspended\",\"normal\"};`\n54\tconst STAT_NAMES: [&[u8]; 4] = [b\"running\", b\"dead\", b\"suspended\", b\"normal\"];\n55\t\n56\t// ── Registration table ────────────────────────────────────────────────────────\n57\t\n58\t/// Registration table for the `coroutine` standard library.\n59\t///\n60\t/// C: `static const luaL_Reg co_funcs[]`\n61\t///\n62\t/// Each entry is `(name_bytes, function_pointer)`. Phase B resolves\n63\t/// `lua_CFunction` to the canonical type alias from `lua-types`.\n64\tpub const CO_FUNCS: &[(&[u8], lua_CFunction)] = &[\n65\t    (b\"create\",      co_create),\n66\t    (b\"resume\",      co_resume),\n67\t    (b\"running\",     co_running),\n68\t    (b\"status\",      co_status),\n69\t    (b\"wrap\",        co_wrap),\n70\t    (b\"yield\",       co_yield),\n71\t    (b\"isyieldable\", co_isyieldable),\n72\t    (b\"close\",       co_close),\n73\t];\n74\t\n75\t// ── Internal helpers ──────────────────────────────────────────────────────────\n76\t\n77\t/// Retrieves the coroutine thread at stack index 1, raising a type error if\n78\t/// the argument is absent or not a thread.\n79\t///\n80\t/// C: `static lua_State *getco(lua_State *L)`\n81\tfn get_co(state: &mut LuaState) -> Result<GcRef<lua_types::value::LuaThread>, LuaError> {\n82\t    let co = state.to_thread(1);\n83\t    if co.is_none() {\n84\t        let got = state.arg(1);\n85\t        return Err(LuaError::type_arg_error(1, \"thread\", &got));\n86\t    }\n87\t    Ok(co.expect(\"checked above\"))\n88\t}\n89\t\n90\t/// Returns one of the `COS_*` status codes describing `co` relative to the\n91\t/// calling thread `state`. Mirrors `auxstatus` in `lcorolib.c` exactly,\n92\t/// reading the target coroutine's `status`, call-frame depth, and stack\n93\t/// top through `GlobalState::threads`.\n94\t///\n95\t/// The main thread (id 0) is never stored in the registry, so a value\n96\t/// pointing at it is always \"running\" when it is the current thread.\n97\t/// Phase E-1 cannot resume coroutines, so any registry-resident thread\n98\t/// is either suspended (initial state, function still on stack) or dead\n99\t/// (empty stack).\n100\t///\n101\t/// C: `static int auxstatus(lua_State *L, lua_State *co)`\n102\tfn aux_status(state: &mut LuaState, co: &GcRef<lua_types::value::LuaThread>) -> i32 {\n103\t    let co_id = co.id;\n104\t    let entry_rc = {\n105\t        let g = state.global();\n106\t        if co_id == g.current_thread_id {\n107\t            return COS_RUN;\n108\t        }\n109\t        match g.threads.get(&co_id) {\n110\t            Some(e) => e.state.clone(),\n111\t            None => return COS_DEAD,\n112\t        }\n113\t    };\n114\t    let co_state = entry_rc.borrow();\n115\t    let raw_status = co_state.status;\n116\t    if raw_status == LuaStatus::Yield as u8 {\n117\t        return COS_YIELD;\n118\t    }\n119\t    if raw_status != LuaStatus::Ok as u8 {\n120\t        return COS_DEAD;\n121\t    }\n122\t    let has_frames = co_state.ci.as_usize() > 0;\n123\t    if has_frames {\n124\t        return COS_NORM;\n125\t    }\n126\t    let ci_func = co_state.call_info[0].func.0;\n127\t    let top = co_state.top.0;\n128\t    let lua_gettop = top as i64 - ci_func as i64 - 1;\n129\t    if lua_gettop == 0 {\n130\t        COS_DEAD\n131\t    } else {\n132\t        COS_YIELD\n133\t    }\n134\t}\n135\t\n136\t/// Transfers `narg` arguments from `state` to `co`, resumes the coroutine,\n137\t/// then transfers results (or error message) back to `state`.\n138\t///\n139\t/// Returns the number of result values (≥ 0) on success, or `-1` on error\n140\t/// with the error object left on top of `state`'s stack.\n141\t///\n142\t/// C: `static int auxresume(lua_State *L, lua_State *co, int narg)`\n143\tfn aux_resume(state: &mut LuaState, co: GcRef<lua_types::value::LuaThread>, narg: i32) -> i32 {\n144\t    let co_id = co.id;\n145\t    let entry_rc = {\n146\t        let g = state.global();\n147\t        match g.threads.get(&co_id) {\n148\t            Some(e) => e.state.clone(),\n149\t            None => {\n150\t                drop(g);\n151\t                push_lit_or_nil(state, b\"cannot resume dead coroutine\");\n152\t                return -1;\n153\t            }\n154\t        }\n155\t    };\n156\t    let parent_thread_id = state.global().current_thread_id;\n157\t    let top_before = state.get_top();\n158\t    if top_before < narg {\n159\t        push_lit_or_nil(state, b\"not enough arguments to resume\");\n160\t        return -1;\n161\t    }\n162\t    let first_arg_idx = top_before - narg + 1;\n163\t    let args: Vec<LuaValue> = (first_arg_idx..=top_before)\n164\t        .map(|i| state.value_at(i))\n165\t        .collect();\n166\t    lua_vm::api::set_top(state, (top_before - narg) as i32).ok();\n167\t\n168\t    let (status, results_or_err): (LuaStatus, Vec<LuaValue>) = {\n169\t        let mut co_state = entry_rc.borrow_mut();\n170\t        if co_state.check_stack(narg + 1).is_err() {\n171\t            drop(co_state);\n172\t            push_lit_or_nil(state, b\"too many arguments to resume\");\n173\t            return -1;\n174\t        }\n175\t        for v in args {\n176\t            co_state.push(v);\n177\t        }\n178\t        co_state.global_mut().current_thread_id = co_id;\n179\t        let mut nres: i32 = 0;\n180\t        let status = lua_vm::do_::lua_resume(&mut *co_state, Some(state), narg, &mut nres);\n181\t        co_state.global_mut().current_thread_id = parent_thread_id;\n182\t        let co_top = co_state.top_idx().0 as i32;\n183\t        let ci_func = co_state.current_call_info().func.0 as i32;\n184\t        let count = if status == LuaStatus::Ok || status == LuaStatus::Yield {\n185\t            nres\n186\t        } else {\n187\t            1\n188\t        };\n189\t        let start = co_top - count;\n190\t        let vals: Vec<LuaValue> = (start..co_top)\n191\t            .map(|i| co_state.get_at(lua_vm::state::StackIdx(i as u32)))\n192\t            .collect();\n193\t        let new_co_top = if status == LuaStatus::Ok || status == LuaStatus::Yield {\n194\t            (co_top - count).max(ci_func + 1)\n195\t        } else {\n196\t            ci_func + 1\n197\t        };\n198\t        co_state.set_top(lua_vm::state::StackIdx(new_co_top.max(0) as u32));\n199\t        (status, vals)\n200\t    };\n201\t\n202\t    match status {\n203\t        LuaStatus::Ok | LuaStatus::Yield => {\n204\t            if state.check_stack(results_or_err.len() as i32 + 1).is_err() {\n205\t                push_lit_or_nil(state, b\"too many results to resume\");\n206\t                return -1;\n207\t            }\n208\t            let n = results_or_err.len();\n209\t            for v in results_or_err {\n210\t                state.push(v);\n211\t            }\n212\t            n as i32\n213\t        }\n214\t        _ => {\n215\t            for v in results_or_err {\n216\t                state.push(v);\n217\t            }\n218\t            -1\n219\t        }\n220\t    }\n221\t}\n222\t\n223\t/// Helper: push a string literal or fall back to Nil on intern failure.\n224\tfn push_lit_or_nil(state: &mut LuaState, bytes: &[u8]) {\n225\t    match state.intern_str(bytes) {\n226\t        Ok(s) => state.push(LuaValue::Str(s)),\n227\t        Err(_) => state.push(LuaValue::Nil),\n228\t    }\n229\t}\n230\t\n231\t// ── Public library functions ──────────────────────────────────────────────────\n232\t\n233\t/// `coroutine.resume(co [, val1, ...])` — attempt to resume coroutine `co`.\n234\t///\n235\t/// On success pushes `true` followed by all values yielded or returned by `co`.\n236\t/// On failure pushes `false` followed by the error object.\n237\t///\n238\t/// C: `static int luaB_coresume(lua_State *L)`\n239\tpub fn co_resume(state: &mut LuaState) -> Result<usize, LuaError> {\n240\t    // C: lua_State *co = getco(L);\n241\t    let co = get_co(state)?;\n242\t    // C: r = auxresume(L, co, lua_gettop(L) - 1);\n243\t    // PORT NOTE: lua_gettop returns the argument count; -1 excludes the coroutine\n244\t    // itself which sits at index 1.\n245\t    let narg = state.get_top() - 1;\n246\t    let r = aux_resume(state, co, narg);\n247\t    if r < 0 {\n248\t        // C: lua_pushboolean(L, 0); lua_insert(L, -2); return 2;\n249\t        state.push(LuaValue::Bool(false));\n250\t        state.insert(-2);\n251\t        Ok(2)\n252\t    } else {\n253\t        // C: lua_pushboolean(L, 1); lua_insert(L, -(r + 1)); return r + 1;\n254\t        state.push(LuaValue::Bool(true));\n255\t        state.insert(-(r + 1));\n256\t        Ok((r + 1) as usize)\n257\t    }\n258\t}\n259\t\n260\t/// Closure body installed by `coroutine.wrap`. The wrapped coroutine\n261\t/// thread is stored in upvalue slot 1 as a `LuaValue::Thread`.\n262\t///\n263\t/// On call: forwards all args to `aux_resume` on the captured thread. On\n264\t/// success returns the yielded/returned values; on coroutine error raises\n265\t/// the error (matching `select(2, assert(resume(co, ...)))` semantics).\n266\t///\n267\t/// C: `static int luaB_auxwrap(lua_State *L)`\n268\tfn aux_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n269\t    let up = state.value_at(upvalue_index(1));\n270\t    let co = match up {\n271\t        LuaValue::Thread(t) => t,\n272\t        _ => {\n273\t            return Err(LuaError::runtime(format_args!(\n274\t                \"coroutine.wrap: upvalue is not a thread\"\n275\t            )))\n276\t        }\n277\t    };\n278\t    let narg = state.get_top();\n279\t    let r = aux_resume(state, co, narg);\n280\t    if r < 0 {\n281\t        let top = state.get_top();\n282\t        let err_val = state.value_at(top);\n283\t        Err(LuaError::from_value(err_val))\n284\t    } else {\n285\t        Ok(r as usize)\n286\t    }\n287\t}\n288\t\n289\t/// Close all open upvalues of `val` (and transitively of any Lua closures\n290\t/// it refers to) by copying their current values from the parent thread's\n291\t/// stack into the `UpVal` struct.\n292\t///\n293\t/// When a closure is transferred to a new coroutine, its open upvalues\n294\t/// point into the parent thread's stack by `StackIdx`. The coroutine has\n295\t/// its own separate `stack` Vec, so reading an open upvalue from inside\n296\t/// the coroutine would access the wrong slot. Closing upvalues before\n297\t/// transfer converts `Open { idx }` → `Closed(current_value)`, making\n298\t/// the value self-contained and accessible across thread boundaries.\n299\t///\n300\t/// Recursion terminates because closing an upvalue changes it from\n301\t/// `Open` to `Closed`; any cycle (e.g. a self-referential `local function`)\n302\t/// is therefore visited at most twice before the second pass is a no-op.\n303\tfn close_open_upvals_for_coroutine(state: &mut LuaState, val: &LuaValue) {\n304\t    let cl = match val {\n305\t        LuaValue::Function(LuaClosure::Lua(cl)) => cl.clone(),\n306\t        _ => return,\n307\t    };\n308\t    for uv_cell in cl.upvals.iter() {\n309\t        let uv = uv_cell.borrow().clone();\n310\t        let idx_opt = match &*uv.slot() {\n311\t            UpValState::Open { idx, .. } => Some(*idx),\n312\t            UpValState::Closed(_) => None,\n313\t        };\n314\t        let idx = match idx_opt {\n315\t            Some(i) => i,\n316\t            None => continue,\n317\t        };\n318\t        let v = state.stack\n319\t            .get(idx.0 as usize)\n320\t            .map(|s| s.val.clone())\n321\t            .unwrap_or(LuaValue::Nil);\n322\t        eprintln!(\"[DBG close_upval] idx={} val={:?}\", idx.0, v);\n323\t        *uv.state.borrow_mut() = UpValState::Closed(v.clone());\n324\t        state.openupval.retain(|u| !GcRef::ptr_eq(u, &uv));\n325\t        close_open_upvals_for_coroutine(state, &v);\n326\t    }\n327\t}\n328\t\n329\t/// `coroutine.create(f)` — create a new coroutine that will run function `f`.\n330\t///\n331\t/// Pushes the new thread value and returns 1.\n332\t///\n333\t/// Phase E-1: allocates a real `LuaState` registered in\n334\t/// `GlobalState::threads`, with `f` staged on the new thread's stack so\n335\t/// `coroutine.status` reports `\"suspended\"`. The full `xmove` from the\n336\t/// caller's stack arrives in slice 02b; for this slice the body is\n337\t/// cloned via `value_at(1)`, which has the same net stack effect since\n338\t/// `lua_newthread` in C also leaves only the thread value on the\n339\t/// caller's stack.\n340\t///\n341\t/// C: `static int luaB_cocreate(lua_State *L)`\n342\tpub fn co_create(state: &mut LuaState) -> Result<usize, LuaError> {\n343\t    state.check_arg_type(1, LuaType::Function)?;\n344\t    let body = state.value_at(1);\n345\t    close_open_upvals_for_coroutine(state, &body);\n346\t    let _nl = state.new_thread(Some(body))?;\n347\t    Ok(1)\n348\t}\n349\t\n350\t/// `coroutine.wrap(f)` — create a coroutine and return a resuming function.\n351\t///\n352\t/// The returned function, when called, resumes the coroutine as if by\n353\t/// `coroutine.resume`, but raises an error rather than returning `false`.\n354\t///\n355\t/// C: `static int luaB_cowrap(lua_State *L)`\n356\t///\n357\t/// Captures the new coroutine thread as upvalue 1 of `aux_wrap`.\n358\tpub fn co_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n359\t    co_create(state)?;\n360\t    state.push_cclosure(aux_wrap, 1)?;\n361\t    Ok(1)\n362\t}\n363\t\n364\t/// `coroutine.yield([...])` — suspend the running coroutine.\n365\t///\n366\t/// All arguments are passed back as results of the corresponding `resume`.\n367\t///\n368\t/// C: `static int luaB_yield(lua_State *L)`\n369\t/// → `return lua_yield(L, lua_gettop(L));`\n370\t/// → `lua_yield(L,n)` is `lua_yieldk(L, n, 0, NULL)` (lua.h:316)\n371\tpub fn co_yield(state: &mut LuaState) -> Result<usize, LuaError> {\n372\t    let n = state.get_top();\n373\t    let r = lua_vm::do_::lua_yieldk(state, n, 0, None)?;\n374\t    Ok(r as usize)\n375\t}\n376\t\n377\t/// `coroutine.status(co)` — return a string describing `co`'s current status.\n378\t///\n379\t/// Returns one of `\"running\"`, `\"dead\"`, `\"suspended\"`, or `\"normal\"`.\n380\t///\n381\t/// C: `static int luaB_costatus(lua_State *L)`\n382\tpub fn co_status(state: &mut LuaState) -> Result<usize, LuaError> {\n383\t    // C: lua_State *co = getco(L);\n384\t    let co = get_co(state)?;\n385\t    // C: lua_pushstring(L, statname[auxstatus(L, co)]);\n386\t    let idx = aux_status(state, &co) as usize;\n387\t    let name: &[u8] = STAT_NAMES[idx];\n388\t    let interned = state.intern_str(name)?;\n389\t    state.push(LuaValue::Str(interned));\n390\t    Ok(1)\n391\t}\n392\t\n393\t/// `coroutine.isyieldable([co])` — test whether a coroutine (default: current)\n394\t/// is in a yieldable state.\n395\t///\n396\t/// C: `static int luaB_yieldable(lua_State *L)`\n397\tpub fn co_isyieldable(state: &mut LuaState) -> Result<usize, LuaError> {\n398\t    let is_yieldable = if matches!(state.type_at(1), LuaType::None) {\n399\t        state.is_yieldable()\n400\t    } else {\n401\t        let co = get_co(state)?;\n402\t        let co_id = co.id;\n403\t        let entry_rc = {\n404\t            let g = state.global();\n405\t            if co_id == g.main_thread_id {\n406\t                None\n407\t            } else {\n408\t                Some(g\n409\t                    .threads\n410\t                    .get(&co_id)\n411\t                    .expect(\"thread value carries an id that must resolve in GlobalState::threads\")\n412\t                    .state\n413\t                    .clone())\n414\t            }\n415\t        };\n416\t        match entry_rc {\n417\t            None => false,\n418\t            Some(rc) => rc.borrow().is_yieldable(),\n419\t        }\n420\t    };\n421\t    state.push(LuaValue::Bool(is_yieldable));\n422\t    Ok(1)\n423\t}\n424\t\n425\t/// `coroutine.running()` — return the current coroutine plus a boolean.\n426\t///\n427\t/// The boolean is `true` when the current coroutine is the main thread.\n428\t///\n429\t/// C: `static int luaB_corunning(lua_State *L)`\n430\tpub fn co_running(state: &mut LuaState) -> Result<usize, LuaError> {\n431\t    // C: int ismain = lua_pushthread(L);\n432\t    // TODO(port): push_thread pushes a Thread value for the current LuaState and\n433\t    // returns true iff it is the main thread; Phase B wire-up needed.\n434\t    let is_main = state.push_thread()?;\n435\t    // C: lua_pushboolean(L, ismain);\n436\t    state.push(LuaValue::Bool(is_main));\n437\t    Ok(2)\n438\t}\n439\t\n440\t/// `coroutine.close(co)` — close a dead or suspended coroutine.\n441\t///\n442\t/// For a dead or suspended coroutine, runs all `__close` metamethods for\n443\t/// any to-be-closed variables remaining on the coroutine's stack (LIFO\n444\t/// order) and resets the thread to a dead state. Returns `true` on clean\n445\t/// completion, or `(false, errobj)` if a `__close` raised an error or the\n446\t/// coroutine was already dead with an uncaught error.\n447\t///\n448\t/// Calling on a running or normal coroutine raises an error.\n449\t///\n450\t/// C: `static int luaB_close(lua_State *L)`\n451\tpub fn co_close(state: &mut LuaState) -> Result<usize, LuaError> {\n452\t    let co = get_co(state)?;\n453\t    let status = aux_status(state, &co);\n454\t    match status {\n455\t        COS_DEAD | COS_YIELD => close_suspended_or_dead(state, co),\n456\t        _ => {\n457\t            let name = STAT_NAMES[status as usize];\n458\t            Err(LuaError::runtime(format_args!(\n459\t                \"cannot close a {} coroutine\",\n460\t                name.escape_ascii()\n461\t            )))\n462\t        }\n463\t    }\n464\t}\n465\t\n466\t/// Performs the actual close for a suspended or dead coroutine.\n467\t///\n468\t/// Borrows the target coroutine's `LuaState`, swaps `current_thread_id`\n469\t/// into the closing thread (so any `__close` body sees the correct\n470\t/// running thread), invokes `lua_vm::state::close_thread` which runs the\n471\t/// tbc-list close loop, then swaps back.\n472\t///\n473\t/// On success pushes `true` and returns 1.\n474\t/// On error pushes `(false, errobj)`; the error object is moved from\n475\t/// the coroutine's stack — mirroring C-Lua's `lua_xmove(co, L, 1)` —\n476\t/// after the close path leaves it at slot 1 on the coroutine.\n477\tfn close_suspended_or_dead(\n478\t    state: &mut LuaState,\n479\t    co: GcRef<lua_types::value::LuaThread>,\n480\t) -> Result<usize, LuaError> {\n481\t    let co_id = co.id;\n482\t    let entry_rc_opt = {\n483\t        let g = state.global();\n484\t        g.threads.get(&co_id).map(|e| e.state.clone())\n485\t    };\n486\t    let entry_rc = match entry_rc_opt {\n487\t        Some(rc) => rc,\n488\t        None => {\n489\t            state.push(LuaValue::Bool(true));\n490\t            return Ok(1);\n491\t        }\n492\t    };\n493\t    let parent_thread_id = state.global().current_thread_id;\n494\t    let caller_c_calls = state.c_calls();\n495\t\n496\t    let (status, err_value): (i32, Option<LuaValue>) = {\n497\t        let mut co_state = entry_rc.borrow_mut();\n498\t        co_state.global_mut().current_thread_id = co_id;\n499\t        co_state.nCcalls = caller_c_calls;\n500\t        let in_status = co_state.status as i32;\n501\t        let s = lua_vm::state::reset_thread(&mut *co_state, in_status);\n502\t        co_state.global_mut().current_thread_id = parent_thread_id;\n503\t        if s == LuaStatus::Ok as i32 {\n504\t            (s, None)\n505\t        } else {\n506\t            let top = co_state.top_idx().0;\n507\t            if top > 0 {\n508\t                let err = co_state.get_at(lua_vm::state::StackIdx(top - 1));\n509\t                co_state.set_top(lua_vm::state::StackIdx(top - 1));\n510\t                (s, Some(err))\n511\t            } else {\n512\t                (s, Some(LuaValue::Nil))\n513\t            }\n514\t        }\n515\t    };\n516\t\n517\t    if status == LuaStatus::Ok as i32 {\n518\t        state.push(LuaValue::Bool(true));\n519\t        Ok(1)\n520\t    } else {\n521\t        state.push(LuaValue::Bool(false));\n522\t        if let Some(v) = err_value {\n523\t            state.push(v);\n524\t        } else {\n525\t            state.push(LuaValue::Nil);\n526\t        }\n527\t        Ok(2)\n528\t    }\n529\t}\n530\t\n531\t// ── Module entry point ────────────────────────────────────────────────────────\n532\t\n533\t/// Opens the `coroutine` standard library by pushing a new table containing\n534\t/// all `coroutine.*` functions.\n535\t///\n536\t/// C: `LUAMOD_API int luaopen_coroutine(lua_State *L)` — `LUAMOD_API` → `pub`.\n537\tpub fn open_coroutine(state: &mut LuaState) -> Result<usize, LuaError> {\n538\t    // C: luaL_newlib(L, co_funcs);\n539\t    // TODO(port): state.new_lib(CO_FUNCS) creates a table from the registration\n540\t    // slice and leaves it on the stack; Phase B wire-up needed.\n541\t    state.new_lib(CO_FUNCS)?;\n542\t    Ok(1)\n543\t}\n544\t\n545\t// ──────────────────────────────────────────────────────────────────────────────\n546\t// PORT STATUS\n547\t//   source:        src/lcorolib.c  (210 lines, 12 functions)\n548\t//   target_crate:  lua-stdlib\n549\t//   confidence:    medium\n550\t//   todos:         21\n551\t//   port_notes:    2\n552\t//   unsafe_blocks: 0\n553\t//   notes:         Phase E-2 (slices 02a/02b) wired real resume/yield. Phase\n554\t//                  E-4 (this slice, 02d) replaces the close_suspended/dead\n555\t//                  stub with a real lua_closethread invocation: it borrows\n556\t//                  the target coroutine, swaps current_thread_id, calls\n557\t//                  lua_vm::state::reset_thread (which now runs\n558\t//                  close_protected so __close metamethods fire on\n559\t//                  to-be-closed locals), and packages the resulting\n560\t//                  status as `(true)` or `(false, errobj)`.\n561\t// ──────────────────────────────────────────────────────────────────────────────\n562\t"}]},"parent_tool_use_id":null,"session_id":"e41a7a40-0733-4140-a39a-79fe7f5c39df","uuid":"4942cb4f-baff-4ef9-97e4-f6af799fad4c","timestamp":"2026-05-19T04:08:04.750Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ianmclaughlin/PycharmProjects/rustExperiments/lua-rs-port/crates/lua-stdlib/src/coro_lib.rs","content":"//! Coroutine library — port of `lcorolib.c`.\n//!\n//! Provides the `coroutine.*` standard-library table: `create`, `resume`,\n//! `running`, `status`, `wrap`, `yield`, `isyieldable`, and `close`.\n//!\n//! # Phase A–D stub notice\n//!\n//! Every function that requires actual coroutine execution (`resume`, `yield`,\n//! cross-thread `xmove`, `new_thread`, `close_thread`) is **unimplemented** and\n//! will panic at runtime.  The argument-checking and result-packaging logic is\n//! translated faithfully so that Phase E can drop in the real implementations\n//! without restructuring.  Phase E wires real stackful coroutines via\n//! `corosensei`.  See PORTING.md §2 #6.\n//!\n//! Translated from: `reference/lua-5.4.7/src/lcorolib.c` (210 lines, 12 functions)\n//! Target crate: `lua-stdlib`\n\n// TODO(port): LuaState, GcRef<LuaState>, LuaStatus, and related types live in\n// lua-vm / lua-types; all unresolved imports will be fixed in Phase B.\nuse lua_types::{\n    error::LuaError,\n    value::LuaValue,\n    LuaType,\n    LuaStatus,\n    LuaClosure,\n    UpValState,\n    gc::GcRef,\n};\nuse crate::state_stub::{LuaState, LuaStateStubExt as _, lua_CFunction, upvalue_index};\n\n// ── Coroutine status codes ────────────────────────────────────────────────────\n\n// C: #define COS_RUN   0\n// C: #define COS_DEAD  1\n// C: #define COS_YIELD 2\n// C: #define COS_NORM  3\n\n/// Coroutine is the currently running thread.\nconst COS_RUN: i32 = 0;\n\n/// Coroutine has finished execution or encountered an error.\nconst COS_DEAD: i32 = 1;\n\n/// Coroutine is suspended — either yielded or not yet started.\nconst COS_YIELD: i32 = 2;\n\n/// Coroutine is normal — it resumed another coroutine and is waiting.\nconst COS_NORM: i32 = 3;\n\n/// Human-readable status strings indexed by the `COS_*` constants above.\n/// Pushed onto the Lua stack as byte strings.\n///\n/// C: `static const char *const statname[] = {\"running\",\"dead\",\"suspended\",\"normal\"};`\nconst STAT_NAMES: [&[u8]; 4] = [b\"running\", b\"dead\", b\"suspended\", b\"normal\"];\n\n// ── Registration table ────────────────────────────────────────────────────────\n\n/// Registration table for the `coroutine` standard library.\n///\n/// C: `static const luaL_Reg co_funcs[]`\n///\n/// Each entry is `(name_bytes, function_pointer)`. Phase B resolves\n/// `lua_CFunction` to the canonical type alias from `lua-types`.\npub const CO_FUNCS: &[(&[u8], lua_CFunction)] = &[\n    (b\"create\",      co_create),\n    (b\"resume\",      co_resume),\n    (b\"running\",     co_running),\n    (b\"status\",      co_status),\n    (b\"wrap\",        co_wrap),\n    (b\"yield\",       co_yield),\n    (b\"isyieldable\", co_isyieldable),\n    (b\"close\",       co_close),\n];\n\n// ── Internal helpers ──────────────────────────────────────────────────────────\n\n/// Retrieves the coroutine thread at stack index 1, raising a type error if\n/// the argument is absent or not a thread.\n///\n/// C: `static lua_State *getco(lua_State *L)`\nfn get_co(state: &mut LuaState) -> Result<GcRef<lua_types::value::LuaThread>, LuaError> {\n    let co = state.to_thread(1);\n    if co.is_none() {\n        let got = state.arg(1);\n        return Err(LuaError::type_arg_error(1, \"thread\", &got));\n    }\n    Ok(co.expect(\"checked above\"))\n}\n\n/// Returns one of the `COS_*` status codes describing `co` relative to the\n/// calling thread `state`. Mirrors `auxstatus` in `lcorolib.c` exactly,\n/// reading the target coroutine's `status`, call-frame depth, and stack\n/// top through `GlobalState::threads`.\n///\n/// The main thread (id 0) is never stored in the registry, so a value\n/// pointing at it is always \"running\" when it is the current thread.\n/// Phase E-1 cannot resume coroutines, so any registry-resident thread\n/// is either suspended (initial state, function still on stack) or dead\n/// (empty stack).\n///\n/// C: `static int auxstatus(lua_State *L, lua_State *co)`\nfn aux_status(state: &mut LuaState, co: &GcRef<lua_types::value::LuaThread>) -> i32 {\n    let co_id = co.id;\n    let entry_rc = {\n        let g = state.global();\n        if co_id == g.current_thread_id {\n            return COS_RUN;\n        }\n        match g.threads.get(&co_id) {\n            Some(e) => e.state.clone(),\n            None => return COS_DEAD,\n        }\n    };\n    let co_state = entry_rc.borrow();\n    let raw_status = co_state.status;\n    if raw_status == LuaStatus::Yield as u8 {\n        return COS_YIELD;\n    }\n    if raw_status != LuaStatus::Ok as u8 {\n        return COS_DEAD;\n    }\n    let has_frames = co_state.ci.as_usize() > 0;\n    if has_frames {\n        return COS_NORM;\n    }\n    let ci_func = co_state.call_info[0].func.0;\n    let top = co_state.top.0;\n    let lua_gettop = top as i64 - ci_func as i64 - 1;\n    if lua_gettop == 0 {\n        COS_DEAD\n    } else {\n        COS_YIELD\n    }\n}\n\n/// Transfers `narg` arguments from `state` to `co`, resumes the coroutine,\n/// then transfers results (or error message) back to `state`.\n///\n/// Returns the number of result values (≥ 0) on success, or `-1` on error\n/// with the error object left on top of `state`'s stack.\n///\n/// C: `static int auxresume(lua_State *L, lua_State *co, int narg)`\nfn aux_resume(state: &mut LuaState, co: GcRef<lua_types::value::LuaThread>, narg: i32) -> i32 {\n    let co_id = co.id;\n    let entry_rc = {\n        let g = state.global();\n        match g.threads.get(&co_id) {\n            Some(e) => e.state.clone(),\n            None => {\n                drop(g);\n                push_lit_or_nil(state, b\"cannot resume dead coroutine\");\n                return -1;\n            }\n        }\n    };\n    let parent_thread_id = state.global().current_thread_id;\n    let top_before = state.get_top();\n    if top_before < narg {\n        push_lit_or_nil(state, b\"not enough arguments to resume\");\n        return -1;\n    }\n    let first_arg_idx = top_before - narg + 1;\n    let args: Vec<LuaValue> = (first_arg_idx..=top_before)\n        .map(|i| state.value_at(i))\n        .collect();\n    lua_vm::api::set_top(state, (top_before - narg) as i32).ok();\n\n    let (status, results_or_err): (LuaStatus, Vec<LuaValue>) = {\n        let mut co_state = entry_rc.borrow_mut();\n        if co_state.check_stack(narg + 1).is_err() {\n            drop(co_state);\n            push_lit_or_nil(state, b\"too many arguments to resume\");\n            return -1;\n        }\n        for v in args {\n            co_state.push(v);\n        }\n        co_state.global_mut().current_thread_id = co_id;\n        let mut nres: i32 = 0;\n        let status = lua_vm::do_::lua_resume(&mut *co_state, Some(state), narg, &mut nres);\n        co_state.global_mut().current_thread_id = parent_thread_id;\n        let co_top = co_state.top_idx().0 as i32;\n        let ci_func = co_state.current_call_info().func.0 as i32;\n        let count = if status == LuaStatus::Ok || status == LuaStatus::Yield {\n            nres\n        } else {\n            1\n        };\n        let start = co_top - count;\n        let vals: Vec<LuaValue> = (start..co_top)\n            .map(|i| co_state.get_at(lua_vm::state::StackIdx(i as u32)))\n            .collect();\n        let new_co_top = if status == LuaStatus::Ok || status == LuaStatus::Yield {\n            (co_top - count).max(ci_func + 1)\n        } else {\n            ci_func + 1\n        };\n        co_state.set_top(lua_vm::state::StackIdx(new_co_top.max(0) as u32));\n        (status, vals)\n    };\n\n    match status {\n        LuaStatus::Ok | LuaStatus::Yield => {\n            if state.check_stack(results_or_err.len() as i32 + 1).is_err() {\n                push_lit_or_nil(state, b\"too many results to resume\");\n                return -1;\n            }\n            let n = results_or_err.len();\n            for v in results_or_err {\n                state.push(v);\n            }\n            n as i32\n        }\n        _ => {\n            for v in results_or_err {\n                state.push(v);\n            }\n            -1\n        }\n    }\n}\n\n/// Helper: push a string literal or fall back to Nil on intern failure.\nfn push_lit_or_nil(state: &mut LuaState, bytes: &[u8]) {\n    match state.intern_str(bytes) {\n        Ok(s) => state.push(LuaValue::Str(s)),\n        Err(_) => state.push(LuaValue::Nil),\n    }\n}\n\n// ── Public library functions ──────────────────────────────────────────────────\n\n/// `coroutine.resume(co [, val1, ...])` — attempt to resume coroutine `co`.\n///\n/// On success pushes `true` followed by all values yielded or returned by `co`.\n/// On failure pushes `false` followed by the error object.\n///\n/// C: `static int luaB_coresume(lua_State *L)`\npub fn co_resume(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: lua_State *co = getco(L);\n    let co = get_co(state)?;\n    // C: r = auxresume(L, co, lua_gettop(L) - 1);\n    // PORT NOTE: lua_gettop returns the argument count; -1 excludes the coroutine\n    // itself which sits at index 1.\n    let narg = state.get_top() - 1;\n    let r = aux_resume(state, co, narg);\n    if r < 0 {\n        // C: lua_pushboolean(L, 0); lua_insert(L, -2); return 2;\n        state.push(LuaValue::Bool(false));\n        state.insert(-2);\n        Ok(2)\n    } else {\n        // C: lua_pushboolean(L, 1); lua_insert(L, -(r + 1)); return r + 1;\n        state.push(LuaValue::Bool(true));\n        state.insert(-(r + 1));\n        Ok((r + 1) as usize)\n    }\n}\n\n/// Closure body installed by `coroutine.wrap`. The wrapped coroutine\n/// thread is stored in upvalue slot 1 as a `LuaValue::Thread`.\n///\n/// On call: forwards all args to `aux_resume` on the captured thread. On\n/// success returns the yielded/returned values; on coroutine error raises\n/// the error (matching `select(2, assert(resume(co, ...)))` semantics).\n///\n/// C: `static int luaB_auxwrap(lua_State *L)`\nfn aux_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n    let up = state.value_at(upvalue_index(1));\n    let co = match up {\n        LuaValue::Thread(t) => t,\n        _ => {\n            return Err(LuaError::runtime(format_args!(\n                \"coroutine.wrap: upvalue is not a thread\"\n            )))\n        }\n    };\n    let narg = state.get_top();\n    let r = aux_resume(state, co, narg);\n    if r < 0 {\n        let top = state.get_top();\n        let err_val = state.value_at(top);\n        Err(LuaError::from_value(err_val))\n    } else {\n        Ok(r as usize)\n    }\n}\n\n/// Close all open upvalues of `val` (and transitively of any Lua closures\n/// it refers to) by copying their current values from the parent thread's\n/// stack into the `UpVal` struct.\n///\n/// When a closure is transferred to a new coroutine, its open upvalues\n/// point into the parent thread's stack by `StackIdx`. The coroutine has\n/// its own separate `stack` Vec, so reading an open upvalue from inside\n/// the coroutine would access the wrong slot. Closing upvalues before\n/// transfer converts `Open { idx }` → `Closed(current_value)`, making\n/// the value self-contained and accessible across thread boundaries.\n///\n/// Recursion terminates because closing an upvalue changes it from\n/// `Open` to `Closed`; any cycle (e.g. a self-referential `local function`)\n/// is therefore visited at most twice before the second pass is a no-op.\nfn close_open_upvals_for_coroutine(state: &mut LuaState, val: &LuaValue) {\n    let cl = match val {\n        LuaValue::Function(LuaClosure::Lua(cl)) => cl.clone(),\n        _ => return,\n    };\n    for uv_cell in cl.upvals.iter() {\n        let uv = uv_cell.borrow().clone();\n        let idx_opt = match &*uv.slot() {\n            UpValState::Open { idx, .. } => Some(*idx),\n            UpValState::Closed(_) => None,\n        };\n        let idx = match idx_opt {\n            Some(i) => i,\n            None => continue,\n        };\n        let v = state.stack\n            .get(idx.0 as usize)\n            .map(|s| s.val.clone())\n            .unwrap_or(LuaValue::Nil);\n        eprintln!(\"[DBG close_upval] idx={} val={:?}\", idx.0, v);\n        *uv.state.borrow_mut() = UpValState::Closed(v.clone());\n        state.openupval.retain(|u| !GcRef::ptr_eq(u, &uv));\n        close_open_upvals_for_coroutine(state, &v);\n    }\n}\n\n/// `coroutine.create(f)` — create a new coroutine that will run function `f`.\n///\n/// Pushes the new thread value and returns 1.\n///\n/// Phase E-1: allocates a real `LuaState` registered in\n/// `GlobalState::threads`, with `f` staged on the new thread's stack so\n/// `coroutine.status` reports `\"suspended\"`. The full `xmove` from the\n/// caller's stack arrives in slice 02b; for this slice the body is\n/// cloned via `value_at(1)`, which has the same net stack effect since\n/// `lua_newthread` in C also leaves only the thread value on the\n/// caller's stack.\n///\n/// C: `static int luaB_cocreate(lua_State *L)`\npub fn co_create(state: &mut LuaState) -> Result<usize, LuaError> {\n    state.check_arg_type(1, LuaType::Function)?;\n    let body = state.value_at(1);\n    close_open_upvals_for_coroutine(state, &body);\n    let _nl = state.new_thread(Some(body))?;\n    Ok(1)\n}\n\n/// `coroutine.wrap(f)` — create a coroutine and return a resuming function.\n///\n/// The returned function, when called, resumes the coroutine as if by\n/// `coroutine.resume`, but raises an error rather than returning `false`.\n///\n/// C: `static int luaB_cowrap(lua_State *L)`\n///\n/// Captures the new coroutine thread as upvalue 1 of `aux_wrap`.\npub fn co_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n    co_create(state)?;\n    state.push_cclosure(aux_wrap, 1)?;\n    Ok(1)\n}\n\n/// `coroutine.yield([...])` — suspend the running coroutine.\n///\n/// All arguments are passed back as results of the corresponding `resume`.\n///\n/// C: `static int luaB_yield(lua_State *L)`\n/// → `return lua_yield(L, lua_gettop(L));`\n/// → `lua_yield(L,n)` is `lua_yieldk(L, n, 0, NULL)` (lua.h:316)\npub fn co_yield(state: &mut LuaState) -> Result<usize, LuaError> {\n    let n = state.get_top();\n    let r = lua_vm::do_::lua_yieldk(state, n, 0, None)?;\n    Ok(r as usize)\n}\n\n/// `coroutine.status(co)` — return a string describing `co`'s current status.\n///\n/// Returns one of `\"running\"`, `\"dead\"`, `\"suspended\"`, or `\"normal\"`.\n///\n/// C: `static int luaB_costatus(lua_State *L)`\npub fn co_status(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: lua_State *co = getco(L);\n    let co = get_co(state)?;\n    // C: lua_pushstring(L, statname[auxstatus(L, co)]);\n    let idx = aux_status(state, &co) as usize;\n    let name: &[u8] = STAT_NAMES[idx];\n    let interned = state.intern_str(name)?;\n    state.push(LuaValue::Str(interned));\n    Ok(1)\n}\n\n/// `coroutine.isyieldable([co])` — test whether a coroutine (default: current)\n/// is in a yieldable state.\n///\n/// C: `static int luaB_yieldable(lua_State *L)`\npub fn co_isyieldable(state: &mut LuaState) -> Result<usize, LuaError> {\n    let is_yieldable = if matches!(state.type_at(1), LuaType::None) {\n        state.is_yieldable()\n    } else {\n        let co = get_co(state)?;\n        let co_id = co.id;\n        let entry_rc = {\n            let g = state.global();\n            if co_id == g.main_thread_id {\n                None\n            } else {\n                Some(g\n                    .threads\n                    .get(&co_id)\n                    .expect(\"thread value carries an id that must resolve in GlobalState::threads\")\n                    .state\n                    .clone())\n            }\n        };\n        match entry_rc {\n            None => false,\n            Some(rc) => rc.borrow().is_yieldable(),\n        }\n    };\n    state.push(LuaValue::Bool(is_yieldable));\n    Ok(1)\n}\n\n/// `coroutine.running()` — return the current coroutine plus a boolean.\n///\n/// The boolean is `true` when the current coroutine is the main thread.\n///\n/// C: `static int luaB_corunning(lua_State *L)`\npub fn co_running(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: int ismain = lua_pushthread(L);\n    // TODO(port): push_thread pushes a Thread value for the current LuaState and\n    // returns true iff it is the main thread; Phase B wire-up needed.\n    let is_main = state.push_thread()?;\n    // C: lua_pushboolean(L, ismain);\n    state.push(LuaValue::Bool(is_main));\n    Ok(2)\n}\n\n/// `coroutine.close(co)` — close a dead or suspended coroutine.\n///\n/// For a dead or suspended coroutine, runs all `__close` metamethods for\n/// any to-be-closed variables remaining on the coroutine's stack (LIFO\n/// order) and resets the thread to a dead state. Returns `true` on clean\n/// completion, or `(false, errobj)` if a `__close` raised an error or the\n/// coroutine was already dead with an uncaught error.\n///\n/// Calling on a running or normal coroutine raises an error.\n///\n/// C: `static int luaB_close(lua_State *L)`\npub fn co_close(state: &mut LuaState) -> Result<usize, LuaError> {\n    let co = get_co(state)?;\n    let status = aux_status(state, &co);\n    match status {\n        COS_DEAD | COS_YIELD => close_suspended_or_dead(state, co),\n        _ => {\n            let name = STAT_NAMES[status as usize];\n            Err(LuaError::runtime(format_args!(\n                \"cannot close a {} coroutine\",\n                name.escape_ascii()\n            )))\n        }\n    }\n}\n\n/// Performs the actual close for a suspended or dead coroutine.\n///\n/// Borrows the target coroutine's `LuaState`, swaps `current_thread_id`\n/// into the closing thread (so any `__close` body sees the correct\n/// running thread), invokes `lua_vm::state::close_thread` which runs the\n/// tbc-list close loop, then swaps back.\n///\n/// On success pushes `true` and returns 1.\n/// On error pushes `(false, errobj)`; the error object is moved from\n/// the coroutine's stack — mirroring C-Lua's `lua_xmove(co, L, 1)` —\n/// after the close path leaves it at slot 1 on the coroutine.\nfn close_suspended_or_dead(\n    state: &mut LuaState,\n    co: GcRef<lua_types::value::LuaThread>,\n) -> Result<usize, LuaError> {\n    let co_id = co.id;\n    let entry_rc_opt = {\n        let g = state.global();\n        g.threads.get(&co_id).map(|e| e.state.clone())\n    };\n    let entry_rc = match entry_rc_opt {\n        Some(rc) => rc,\n        None => {\n            state.push(LuaValue::Bool(true));\n            return Ok(1);\n        }\n    };\n    let parent_thread_id = state.global().current_thread_id;\n    let caller_c_calls = state.c_calls();\n\n    let (status, err_value): (i32, Option<LuaValue>) = {\n        let mut co_state = entry_rc.borrow_mut();\n        co_state.global_mut().current_thread_id = co_id;\n        co_state.nCcalls = caller_c_calls;\n        let in_status = co_state.status as i32;\n        let s = lua_vm::state::reset_thread(&mut *co_state, in_status);\n        co_state.global_mut().current_thread_id = parent_thread_id;\n        if s == LuaStatus::Ok as i32 {\n            (s, None)\n        } else {\n            let top = co_state.top_idx().0;\n            if top > 0 {\n                let err = co_state.get_at(lua_vm::state::StackIdx(top - 1));\n                co_state.set_top(lua_vm::state::StackIdx(top - 1));\n                (s, Some(err))\n            } else {\n                (s, Some(LuaValue::Nil))\n            }\n        }\n    };\n\n    if status == LuaStatus::Ok as i32 {\n        state.push(LuaValue::Bool(true));\n        Ok(1)\n    } else {\n        state.push(LuaValue::Bool(false));\n        if let Some(v) = err_value {\n            state.push(v);\n        } else {\n            state.push(LuaValue::Nil);\n        }\n        Ok(2)\n    }\n}\n\n// ── Module entry point ────────────────────────────────────────────────────────\n\n/// Opens the `coroutine` standard library by pushing a new table containing\n/// all `coroutine.*` functions.\n///\n/// C: `LUAMOD_API int luaopen_coroutine(lua_State *L)` — `LUAMOD_API` → `pub`.\npub fn open_coroutine(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: luaL_newlib(L, co_funcs);\n    // TODO(port): state.new_lib(CO_FUNCS) creates a table from the registration\n    // slice and leaves it on the stack; Phase B wire-up needed.\n    state.new_lib(CO_FUNCS)?;\n    Ok(1)\n}\n\n// ──────────────────────────────────────────────────────────────────────────────\n// PORT STATUS\n//   source:        src/lcorolib.c  (210 lines, 12 functions)\n//   target_crate:  lua-stdlib\n//   confidence:    medium\n//   todos:         21\n//   port_notes:    2\n//   unsafe_blocks: 0\n//   notes:         Phase E-2 (slices 02a/02b) wired real resume/yield. Phase\n//                  E-4 (this slice, 02d) replaces the close_suspended/dead\n//                  stub with a real lua_closethread invocation: it borrows\n//                  the target coroutine, swaps current_thread_id, calls\n//                  lua_vm::state::reset_thread (which now runs\n//                  close_protected so __close metamethods fire on\n//                  to-be-closed locals), and packages the resulting\n//                  status as `(true)` or `(false, errobj)`.\n// ──────────────────────────────────────────────────────────────────────────────\n","numLines":562,"startLine":1,"totalLines":562}}}
