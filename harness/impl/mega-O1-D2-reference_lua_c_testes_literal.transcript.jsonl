{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PuPzdnmV3eP9gcACngjoS5","type":"tool_result","content":"1279\t/// C: `LUA_API int lua_resume(lua_State *L, lua_State *from, int nargs, int *nresults)`\n1280\tpub fn lua_resume(\n1281\t    state: &mut LuaState,\n1282\t    from: Option<&mut LuaState>,\n1283\t    nargs: i32,\n1284\t    nresults: &mut i32,\n1285\t) -> LuaStatus {\n1286\t    // TODO(port): coroutine support (Phase E). The implementation below is a\n1287\t    // faithful translation of the C logic but will not work correctly until\n1288\t    // coroutine stack switching is available. Phase A: translate the logic;\n1289\t    // Phase E: make it actually work.\n1290\t\n1291\t    // C: lua_lock(L) — no-op\n1292\t    if state.status == LuaStatus::Ok as u8 {\n1293\t        // C: if (L->ci != &L->base_ci) — starting check\n1294\t        if !state.is_base_ci(state.ci) {\n1295\t            return resume_error(state, b\"cannot resume non-suspended coroutine\", nargs);\n1296\t        }\n1297\t        // C: else if (L->top.p - (L->ci->func.p + 1) == nargs) — no function?\n1298\t        let ci_func = state.get_ci(state.ci).func;\n1299\t        if state.top_idx().0 as i32 - (ci_func.0 as i32 + 1) == nargs {\n1300\t            return resume_error(state, b\"cannot resume dead coroutine\", nargs);\n1301\t        }\n1302\t    } else if state.status != LuaStatus::Yield as u8 {\n1303\t        return resume_error(state, b\"cannot resume dead coroutine\", nargs);\n1304\t    }\n1305\t\n1306\t    // C: L->nCcalls = (from) ? getCcalls(from) : 0;\n1307\t    state.nCcalls = from\n1308\t        .as_ref()\n1309\t        .map(|f| f.c_calls() as u32)\n1310\t        .unwrap_or(0);\n1311\t\n1312\t    if state.c_calls() >= LUAI_MAXCCALLS {\n1313\t        return resume_error(state, b\"C stack overflow\", nargs);\n1314\t    }\n1315\t    state.nCcalls += 1;\n1316\t\n1317\t    // C: luai_userstateresume(L, nargs) — no-op (macros.tsv)\n1318\t    // C: api_checknelems(L